# ─────────────────────────────────────────────────────────────
# ResumeAI India — Environment Variables
# Copy this file to `.env.local` and fill in the values.
# Every key here is OPTIONAL for the core flow: if a key is missing,
# the app degrades gracefully (e.g. Gemini falls back to the built-in
# rule-based analyzer, and rate limiting becomes a no-op).
# ─────────────────────────────────────────────────────────────

# Public base URL of the deployed site (used for SEO canonicals, sitemap, OG).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI: Google Gemini (model: gemini-2.0-flash) ───────────────
# Get a key from https://aistudio.google.com/app/apikey
# If absent, the deterministic rule-based analyzer is used instead.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Rate limiting: Upstash Redis ──────────────────────────────
# Create a database at https://console.upstash.com/
# If absent, rate limiting is disabled (no-op) — safe for local dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Salt used to hash visitor IPs before storing usage events (never store raw IPs).
IP_HASH_SALT=change-me-to-a-long-random-string

# ── Supabase (Phase 3: optional accounts, saved history) ──────
# Not required for Phase 1 (anonymous analyze flow).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
